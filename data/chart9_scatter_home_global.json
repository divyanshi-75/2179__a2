{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Home heroes vs world conquerors. Home streams (AU) vs global streams per artist · 2017-2021.",
  "width": "container",
  "height": 380,
  "config": {
    "background": "transparent",
    "font": "DM Sans",
    "view": { "stroke": "transparent" },
    "axis": {
      "grid": false,
      "gridOpacity": 0,
      "domainColor": "rgba(255,255,255,0.08)",
      "tickColor": "transparent",
      "labelColor": "#c8c6c0",
      "titleColor": "#c8c6c0",
      "labelFontSize": 11,
      "titleFontSize": 11
    },
    "legend": {
      "labelColor": "#c8c6c0",
      "titleColor": "#c8c6c0",
      "labelFontSize": 11
    }
  },
  "layer": [
    {
      "data": { "url": "data/aussie_artists_aggregated_fixed.csv" },
      "transform": [
        { "filter": "datum.is_home == 'home'" },
        {
          "aggregate": [{ "op": "sum", "field": "total_streams", "as": "home_streams" }],
          "groupby": ["artist"]
        },
        { "calculate": "datum.home_streams / 1000000", "as": "home_M" },
        {
          "lookup": "artist",
          "from": {
            "data": { "url": "data/aussie_countries_reached_fixed.csv" },
            "key": "artist",
            "fields": ["countries_reached", "global_streams"]
          }
        },
        { "calculate": "datum.global_streams / 1000000", "as": "global_M" },
        { "filter": "datum.global_M > 0" }
      ],
      "mark": { "type": "circle", "clip": true, "filled": true, "opacity": 0.85 },
      "encoding": {
        "x": {
          "field": "home_M",
          "type": "quantitative",
          "scale": { "type": "log", "base": 10, "domainMin": 0.5, "domainMax": 500, "nice": false },
          "title": "Home streams — Australia (M, log scale)",
          "axis": {
            "grid": false,
            "values": [0.1, 1, 2, 5, 10, 20, 50, 100, 200, 500, 1000],
            "labelExpr": "datum.value >= 1 ? datum.label : ''",
            "labelColor": "#c8c6c0",
            "titleColor": "#c8c6c0",
            "labelFontSize": 11,
            "titleFontSize": 11
          }
        },
        "y": {
          "field": "global_M",
          "type": "quantitative",
          "scale": { "type": "log", "base": 10, "domainMin": 0.5, "domainMax": 20000, "nice": false },
          "title": "Global streams (M, log scale)",
          "axis": {
            "grid": false,
            "values": [1, 10, 100, 1000, 10000],
            "labelExpr": "datum.value >= 1 ? datum.label : ''",
            "labelColor": "#c8c6c0",
            "titleColor": "#c8c6c0",
            "labelFontSize": 11,
            "titleFontSize": 11
          }
        },
        "size": {
          "field": "countries_reached",
          "type": "quantitative",
          "scale": { "range": [30, 2000] },
          "legend": null
        },
        "color": {
          "field": "countries_reached",
          "type": "quantitative",
          "scale": { "scheme": "greens", "domainMin": 0 },
          "legend": {
            "title": "Countries reached",
            "titleColor": "#e0deda",
            "labelColor": "#c8c6c0",
            "labelFontSize": 11,
            "titleFontSize": 12,
            "gradientLength": 100,
            "gradientThickness": 10,
            "orient": "right"
          }
        },
        "opacity": {
          "field": "countries_reached",
          "type": "quantitative",
          "scale": { "range": [0.2, 0.95] },
          "legend": null
        },
        "tooltip": [
          { "field": "artist", "type": "nominal", "title": "Artist" },
          { "field": "home_M", "type": "quantitative", "title": "Home streams (M)", "format": ",.1f" },
          { "field": "global_M", "type": "quantitative", "title": "Global streams (M)", "format": ",.1f" },
          { "field": "countries_reached", "type": "quantitative", "title": "Countries reached" }
        ]
      },
      "params": [
        { "name": "hover9", "select": { "type": "point", "on": "mouseover", "fields": ["artist"] } }
      ]
    },
    {
      "data": { "url": "data/aussie_artists_aggregated_fixed.csv" },
      "transform": [
        { "filter": "datum.is_home == 'home'" },
        {
          "aggregate": [{ "op": "sum", "field": "total_streams", "as": "home_streams" }],
          "groupby": ["artist"]
        },
        { "calculate": "datum.home_streams / 1000000", "as": "home_M" },
        {
          "lookup": "artist",
          "from": {
            "data": { "url": "data/aussie_countries_reached_fixed.csv" },
            "key": "artist",
            "fields": ["countries_reached", "global_streams"]
          }
        },
        { "calculate": "datum.global_streams / 1000000", "as": "global_M" },
        { "filter": "datum.global_M > 50" }
      ],
      "mark": {
        "type": "text",
        "clip": true,
        "fontSize": 10,
        "dy": -10,
        "color": "#c8c6c0",
        "fontWeight": 400
      },
      "encoding": {
        "x": {
          "field": "home_M",
          "type": "quantitative",
          "scale": { "type": "log", "base": 10, "domainMin": 0.5, "domainMax": 500, "nice": false }
        },
        "y": {
          "field": "global_M",
          "type": "quantitative",
          "scale": { "type": "log", "base": 10, "domainMin": 0.5, "domainMax": 20000, "nice": false }
        },
        "text": { "field": "artist", "type": "nominal" }
      }
    },
    {
      "data": {"values": [
        {"label": "Bigger + darker green"},
        {"label": "= more countries reached"}
      ]},
      "mark": {
        "type": "text",
        "align": "left",
        "fontSize": 10,
        "fontStyle": "italic"
      },
      "encoding": {
        "x": {"value": 820},
        "y": {"field": "label", "type": "nominal", "sort": null, "axis": null},
        "text": {"field": "label", "type": "nominal"},
        "color": {"value": "#c8c6c0"}
      }
    },




    
    {
      "data": {"values": [{}]},
      "mark": {"type": "rect", "cornerRadius": 4, "clip": false},
      "encoding": {
        "x":           {"value": 8},
