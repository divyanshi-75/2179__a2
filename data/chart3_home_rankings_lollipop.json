      }
    },
    {
      "data": {"values": [{ "label": "globally. Beloved locally."}]},
      "mark": {"type": "text", "align": "center", "fontSize": 12, "fontWeight": "400", "dy": 62},
      "encoding": {
        "x": {"value": 525},
