{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 480,
  "background": "transparent",
  "config": {
    "font": "DM Sans",
    "view": {"stroke": "transparent"},
    "axis": {
      "domainColor": "rgba(255,255,255,0.08)",
      "gridColor": "rgba(255,255,255,0.04)",
      "tickColor": "transparent",
      "labelColor": "#c8c6c0",
      "titleColor": "#c8c6c0",
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "legend": {
      "labelColor": "#c8c6c0",
      "titleColor": "#e0deda",
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  },
  "data": {"url": "data/aussie_artists_aggregated_fixed.csv"},
  "transform": [
    {"filter": "datum.is_home === 'global'"},
    {
      "aggregate": [{"op": "sum", "field": "days_charted", "as": "countries_reached"}],
      "groupby": ["artist", "year"]
    },
    {
      "filter": "datum.countries_reached > 0"
    },
    {
      "window": [{"op": "sum", "field": "countries_reached", "as": "total_artist"}],
      "groupby": ["artist"]
    },
    {
      "filter": "datum.total_artist > 500"
    }
  ],
  "layer": [
    {
      "mark": {"type": "rect", "cornerRadius": 2},
      "encoding": {
        "y": {
          "field": "artist",
          "type": "nominal",
          "sort": {"field": "total_artist", "op": "max", "order": "descending"},
          "title": null,
          "axis": {
            "labelColor": "#c8c6c0",
            "labelFontSize": 12,
            "labelLimit": 160,
            "labels": true,
            "ticks": false,
            "domain": false
          }
        },
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year",
          "axis": {"labelAngle": 0, "labelColor": "#c8c6c0"}
        },
        "color": {
          "field": "countries_reached",
          "type": "quantitative",
          "scale": {"scheme": "greens", "domainMin": 0, "null": "rgba(255,255,255,0.04)"},
          "legend": {
            "title": "Countries charted",
            "titleColor": "#c8c6c0",
            "labelColor": "#c8c6c0",
            "gradientLength": 120,
            "gradientThickness": 10,
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "tooltip": [
          {"field": "artist",            "type": "nominal",     "title": "Artist"},
          {"field": "year",              "type": "ordinal",      "title": "Year"},
          {"field": "countries_reached", "type": "quantitative", "title": "Countries charted"}
        ]
      }
    },
    {
      "data": {"values": [{}]},
      "mark": {
        "type": "rect",
        "width": 14,
        "height": 14,
        "cornerRadius": 2
      },
      "encoding": {
        "x": {"value": 840},
        "y": {"value": 210},
        "color": {"value": "rgba(255,255,255,0.04)"},
        "stroke": {"value": "rgba(255,255,255,0.2)"},
        "strokeWidth": {"value": 0.5}
      }
    },
    {
      "data": {"values": [{"label": "No data"}]},
      "mark": {
        "type": "text",
        "align": "left",
        "fontSize": 11,
        "dx": 10
      },
      "encoding": {
        "x": {"value": 858},
        "y": {"value": 210},
        "text": {"field": "label", "type": "nominal"},
        "color": {"value": "#c8c6c0"}
      }
    },
    {
      "data": {"values": [{}]},
      "mark": {
        "type": "rect",
        "width": 11,
        "height": 11,
        "cornerRadius": 2
      },
      "encoding": {
        "x": {"value": 4},
        "y": {"value": -14},
        "color": {"value": "rgba(255,255,255,0.06)"},
        "stroke": {"value": "rgba(255,255,255,0.2)"},
        "strokeWidth": {"value": 0.5}
      }
    },
    {
      "data": {
        "values": [
          {"label": "No data - artist did not chart globally that year"}
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "fontSize": 11,
        "fontWeight": "400",
        "baseline": "middle"
      },
      "encoding": {
        "x": {"value": 20},
        "y": {"value": -14},
        "text": {"field": "label", "type": "nominal"},
        "color": {"value": "rgba(200,198,192,0.6)"}
      }
    }
  ]
}
